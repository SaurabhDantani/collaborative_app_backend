    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.17",
    "bcrypt": "^5.1.1",
    "concurrently": "^8.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "rimraf": "^5.0.1",
    "socket.io": "^4.7.2"
